# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# App URL (required for staff invite emails — set to your Vercel production URL)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Optional — public /welcome live previews (set after running scripts/seed-demo-showcase.sql)
# LANDING_SHOWCASE_BRANCH_ID=<branch_id from seed JSON result>
# SUPABASE_SERVICE_ROLE_KEY=<service role key — server only, never expose to client>

# PLAYWRIGHT_BASE_URL=https://ph-dental-app.vercel.app
# E2E_TEST_EMAIL=doctor@clinic.com
# E2E_TEST_PASSWORD=your_test_password
# E2E_PATIENT_ID=optional-uuid-to-open-chart-directly
# E2E_STRICT=true
# E2E_BRANCH_ID=staging-branch-uuid
# E2E_SUPABASE_SERVICE_ROLE_KEY=staging-only-service-role-key
